#!/usr/bin/env bash

# Find Git repositories within a directory tree.

set -euo pipefail

shopt -s nullglob

walk() {
  local dir=$1 rel=${2-} entry name

  if [[ -e $dir/.git ]]; then
    printf '%s\n' "${rel:-.}"
    return
  fi

  for entry in "$dir"/*/; do
    entry=${entry%/}
    [[ -L $entry ]] && continue
    name=${entry##*/}

    case $name in
      .venv | target) continue ;;
    esac

    walk "$entry" "${rel:+$rel/}$name"
  done
}

main() {
  local path=${1:-$HOME/Projects}

  if [[ ! -d $path ]]; then
    printf 'error: %s is not a directory\n' "$path" >&2
    return 1
  fi

  walk "$path"
}

main "$@"
