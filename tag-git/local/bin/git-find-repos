#!/usr/bin/env python3

"""Find Git repositories within a directory tree."""

import argparse
import os
from typing import TYPE_CHECKING

if TYPE_CHECKING:
    from collections.abc import Iterable


def find_repos(path: str) -> Iterable[str]:
    """Find all Git repositories in a directory tree.

    Args:
        path: Root directory to start searching from.

    Yields:
        Absolute paths to discovered repositories.
    """
    for dirpath, dirnames, _ in os.walk(path):
        if ".git" in dirnames:
            yield dirpath
            dirnames.clear()


def main() -> None:
    """Command-line entry point."""
    parser = argparse.ArgumentParser(
        description="Find Git repositories in a directory tree"
    )
    parser.add_argument("path", help="directory to search")
    args = parser.parse_args()

    for repo_path in find_repos(args.path):
        print(os.path.relpath(repo_path, start=args.path))


if __name__ == "__main__":
    main()
