# Shell options ---------------------------------------------------------------
setopt EXTENDED_GLOB
setopt INTERACTIVE_COMMENTS
setopt PROMPT_SUBST

WORDCHARS=${WORDCHARS//\/}

# History ---------------------------------------------------------------------
setopt EXTENDED_HISTORY
setopt HIST_EXPIRE_DUPS_FIRST
setopt HIST_FIND_NO_DUPS
setopt HIST_IGNORE_DUPS
setopt HIST_IGNORE_SPACE
setopt HIST_REDUCE_BLANKS
setopt INC_APPEND_HISTORY_TIME

HISTFILE="$HOME/.local/state/zsh_history"
HISTSIZE=10000
SAVEHIST=10000

# Environment -----------------------------------------------------------------
typeset -U path
path=(~/bin ~/.local/bin ~/.cargo/bin /opt/homebrew/bin(N) $path)

export EDITOR="nvim"
export LESS="FRX"
export RIPGREP_CONFIG_PATH="$HOME/.config/ripgrep/config"
export HOMEBREW_NO_ANALYTICS="1"

# Title -----------------------------------------------------------------------
autoload -Uz add-zsh-hook

_collapse_pwd() {
  local current_pwd=${(D)PWD}

  if [[ $current_pwd == [/~] ]]; then
    print -r -- $current_pwd
    return
  fi

  local abbreviated=${(j:/:M)${(s:/:)current_pwd}##.#?}
  local parents=${${abbreviated:h}%/}
  local leaf=${current_pwd:t}

  print -r -- "${parents//\%/%%}/${leaf//\%/%%}"
}

_precmd_title() { print -Pn "\e]0;${SSH_CONNECTION:+%m: }$(_collapse_pwd)\a" }
add-zsh-hook precmd _precmd_title

_preexec_title() { print -Pn "\e]0;${SSH_CONNECTION:+%m: }${2//\%/%%}\a" }
add-zsh-hook preexec _preexec_title

# Keybindings -----------------------------------------------------------------
bindkey -e

autoload -Uz edit-command-line
zle -N edit-command-line
bindkey '^g' edit-command-line

# Completion ------------------------------------------------------------------
autoload -Uz compinit
compinit

zstyle ':completion:*:corrections' format '%F{yellow}Matches for %d (%e errors):%f'
zstyle ':completion:*:descriptions' format '%F{green}Matches for %d:%f'
zstyle ':completion:*:messages' format '%F{purple}%d%f'
zstyle ':completion:*:warnings' format '%F{red}No matches for %d.%f'

zstyle ':completion:*' cache-path "$HOME/.cache/zcompcache"
zstyle ':completion:*' completer _extensions _complete _approximate
zstyle ':completion:*' group-name ''
zstyle ':completion:*' matcher-list 'm:{a-zA-Z}={A-Za-z}' 'r:|[._-]=* r:|=*' 'l:|=* r:|=*'
zstyle ':completion:*' menu select=2
zstyle ':completion:*' rehash true
zstyle ':completion:*' use-cache true
zstyle ':completion:*' verbose true

# Prompt ----------------------------------------------------------------------
autoload -Uz vcs_info
add-zsh-hook precmd vcs_info

+vi-git-truncate-branch() {
  if (( ${#hook_com[branch]} > 25 )); then
    hook_com[branch]="${hook_com[branch]:0:24}â€¦"
  fi
}

+vi-git-stashed() {
  if git rev-parse --verify --quiet refs/stash >/dev/null; then
    hook_com[misc]+='%F{red}%Bâ‰ˇ%b%f'
  fi
}

+vi-git-untracked() {
  if [[ -n $(git ls-files --others --exclude-standard 2>/dev/null) ]]; then
    hook_com[unstaged]+='%F{red}%B?%b%f'
  fi
}

zstyle ':vcs_info:*' enable git
zstyle ':vcs_info:*' check-for-changes true
zstyle ':vcs_info:*' formats ' %F{magenta}%B%b%%b%f%c%u%m'
zstyle ':vcs_info:*' actionformats ' %F{magenta}%B%b%%b%f|%a%c%u%m'
zstyle ':vcs_info:*' unstagedstr '%F{yellow}%B!%b%f'
zstyle ':vcs_info:*' stagedstr '%F{green}%BÂ±%b%f'
zstyle ':vcs_info:git+set-message:*' hooks git-truncate-branch git-stashed git-untracked

PROMPT='%B%F{cyan}%1~%f%b${vcs_info_msg_0_}%(1j. %F{yellow}âś¦%f.) %(?:%F{green}:%F{red})âťŻ%f '

zmodload zsh/datetime

_preexec_duration() {
  typeset -g preexec_epochrealtime=$EPOCHREALTIME
}
add-zsh-hook preexec _preexec_duration

_precmd_duration() {
  unset command_duration
  [[ -v preexec_epochrealtime ]] || return

  local -rF elapsed=$((EPOCHREALTIME - preexec_epochrealtime))
  local -ri hours=$((elapsed / 3600))
  local -ri mins=$(((elapsed / 60) % 60))
  local -ri secs=$((elapsed % 60))

  local formatted
  if ((hours)); then
    printf -v formatted '%ih%im' $hours $mins
  elif ((mins)); then
    printf -v formatted '%im%is' $mins $secs
  elif ((secs >= 1)); then
    printf -v formatted '%is' $secs
  fi

  [[ -n $formatted ]] && command_duration="%F{8}%B${formatted}%b%f "
  unset preexec_epochrealtime
}
add-zsh-hook precmd _precmd_duration

RPROMPT='$command_duration'
if [[ -n $SSH_CONNECTION ]]; then
  RPROMPT+='%F{magenta}%B%m%b%f'
fi

# Functions -------------------------------------------------------------------
cdd() {
  local dir="$(bfs ~/D*/ -type d | fzy)"
  [[ -d "$dir" ]] && cd "$dir"
}

cdr() {
  local repo="$(git-find-repos | fzy)"
  [[ -n "$repo" && -d "$HOME/Projects/$repo" ]] && cd "$HOME/Projects/$repo"
}

opf() {
  local item="$(rg --files | fzy)"
  [[ -n "$item" ]] && open "$item"
}

_jj_lazy() {
  unfunction _jj_lazy
  . <(COMPLETE=zsh jj)
  "$_comps[jj]" "$@"
}
compdef _jj_lazy jj

# Aliases ---------------------------------------------------------------------
alias ls="ls --color -h"
alias ll="ls --color -hl"
alias la="ls --color -Ahl"

# Local configuration ---------------------------------------------------------
if [[ -r "$HOME/.config/zsh/local.zsh" ]]; then
  . "$HOME/.config/zsh/local.zsh"
fi
