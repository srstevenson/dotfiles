font-family = JetBrains Mono
font-size = 15
macos-option-as-alt = left
macos-titlebar-proxy-icon = hidden
mouse-hide-while-typing = true
shell-integration-features = no-title
theme = thalk
unfocused-split-opacity = 1

keybind = ctrl+b=activate_key_table_once:nav
keybind = nav/c=new_tab
keybind = nav/n=next_tab
keybind = nav/p=previous_tab
keybind = nav/s=new_split:down
keybind = nav/v=new_split:right
keybind = nav/h=goto_split:left
keybind = nav/j=goto_split:down
keybind = nav/k=goto_split:up
keybind = nav/l=goto_split:right
