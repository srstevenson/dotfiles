#!/usr/bin/env python3

import argparse
import os
import webbrowser
from urllib.parse import urlencode


def main() -> None:
    """Open Kagi search for a query in the browser."""
    parser = argparse.ArgumentParser(description="Search Kagi")
    parser.add_argument("query", nargs="+", help="search query")
    args = parser.parse_args()

    params = {"q": " ".join(args.query)}
    url = f"https://kagi.com/search?{urlencode(params)}"
    print(url)
    if "SSH_CONNECTION" not in os.environ:
        webbrowser.open(url)


if __name__ == "__main__":
    main()
