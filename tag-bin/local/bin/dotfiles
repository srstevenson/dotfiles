#!/usr/bin/env python3

import argparse
import filecmp
import sys
from pathlib import Path

FG_GREEN = "\033[32;1m"
FG_RED = "\033[31;1m"
FG_RESET = "\033[0m"

HOME_DIR = Path.home().resolve()


def error(message: str, prefix: str = "error") -> None:
    """Print an error message with a red prefix."""
    print(f"{FG_RED}{prefix}{FG_RESET}: {message}", file=sys.stderr)


def info(message: str, prefix: str = "info") -> None:
    """Print an informational message with a green prefix."""
    print(f"{FG_GREEN}{prefix}{FG_RESET}: {message}")


def find_dotfiles_dir() -> Path:
    """Find the dotfiles directory."""
    return Path(__file__).resolve().parents[3]


def add_dot_prefix(path: Path) -> Path:
    """Add a dot prefix to the first part of a path."""
    if path.parts[0].startswith("."):
        raise ValueError(f"path already starts with a dot: {path}")
    return Path("." + path.parts[0], *path.parts[1:])


def remove_dot_prefix(path: Path) -> Path:
    """Remove a leading dot from the first part of a path."""
    return Path(path.parts[0].removeprefix("."), *path.parts[1:])


def normalise_tag(tag: str) -> str:
    """Normalise a tag name by removing an optional `tag-` prefix."""
    return tag.removeprefix("tag-")


def tag_dirs(dotfiles_dir: Path) -> list[Path]:
    """List tag directories within the dotfiles directory."""
    return sorted(
        path
        for path in dotfiles_dir.iterdir()
        if path.is_dir() and path.name.startswith("tag-")
    )


def files_in_tag(tag_dir: Path) -> list[Path]:
    """List files in a tag directory, relative to that directory."""
    return sorted(
        path.relative_to(tag_dir) for path in tag_dir.rglob("*") if path.is_file()
    )


def import_file(
    dotfiles_dir: Path, source: Path, tag: str, *, dry_run: bool = False
) -> None:
    """Import a dotfile into the repository and replace it with a symlink."""
    source = source.absolute()

    if source.is_symlink():
        error(f"{source} is a symbolic link")
        return

    # Resolve after symlink check to get canonical path of the regular file.
    source = source.resolve()

    if source.is_relative_to(dotfiles_dir.resolve()):
        error(f"{source} is in dotfiles directory")
        return

    if not source.is_relative_to(HOME_DIR):
        error(f"{source} is not in home directory")
        return

    if not source.is_file():
        error(f"{source} is not a file")
        return

    path_in_home = source.relative_to(HOME_DIR)
    if not path_in_home.parts[0].startswith("."):
        error(f"{source} is not a dotfile")
        return

    tag_dir = dotfiles_dir.joinpath(f"tag-{normalise_tag(tag)}")
    target = tag_dir.joinpath(remove_dot_prefix(path_in_home))

    if target.exists():
        error(f"{target} already exists")
        return

    tilde_source = f"~/{source.relative_to(HOME_DIR)}"
    tagged_path = target.relative_to(dotfiles_dir)

    if dry_run:
        info(f"{tilde_source} -> {tagged_path}", prefix="imported")
    else:
        target.parent.mkdir(parents=True, exist_ok=True)
        source.rename(target)
        source.symlink_to(target)
        info(f"{tilde_source} -> {tagged_path}", prefix="imported")


def import_files(
    dotfiles_dir: Path, sources: list[Path], tag: str, *, dry_run: bool = False
) -> None:
    """Import multiple files into the repository under a given tag."""
    for source in sources:
        import_file(dotfiles_dir, source, tag, dry_run=dry_run)


def link_file(
    dotfiles_dir: Path, tag_dir: Path, path: Path, *, dry_run: bool = False
) -> None:
    """Create or verify a symlink from the repo into home."""
    source = tag_dir.joinpath(path)
    target = HOME_DIR.joinpath(add_dot_prefix(path))

    tilde_target = f"~/{target.relative_to(HOME_DIR)}"
    tagged_path = source.relative_to(dotfiles_dir)

    if not target.exists():
        if dry_run:
            info(f"{tilde_target} -> {tagged_path}", prefix="linked (created)")
            return

        if target.is_symlink():
            # As target failed existence check, this is a broken symlink.
            target.unlink()

        target.parent.mkdir(parents=True, exist_ok=True)
        target.symlink_to(source)
        info(f"{tilde_target} -> {tagged_path}", prefix="linked (created)")
        return

    if target.is_symlink() and target.resolve() == source.resolve():
        info(f"{tilde_target} -> {tagged_path}", prefix="linked (existing)")
        return

    if target.is_file() and filecmp.cmp(source, target, shallow=False):
        if dry_run:
            info(f"{tilde_target} -> {tagged_path}", prefix="linked (unlinked copy)")
        else:
            target.unlink()
            target.symlink_to(source)
            info(f"{tilde_target} -> {tagged_path}", prefix="linked (unlinked copy)")
            return

    error(f"{tilde_target} -> {tagged_path}", prefix="divergent")


def link_files(dotfiles_dir: Path, *, dry_run: bool = False) -> None:
    """Link one tag or all tags from the repository into home."""
    for tag_dir in tag_dirs(dotfiles_dir):
        for path in files_in_tag(tag_dir):
            link_file(dotfiles_dir, tag_dir, path, dry_run=dry_run)


def file_status(dotfiles_dir: Path, tag_dir: Path, path: Path) -> None:
    """Print status of managed file relative to home."""
    source = tag_dir.joinpath(path)
    target = HOME_DIR.joinpath(add_dot_prefix(path))

    tilde_target = f"~/{target.relative_to(HOME_DIR)}"
    tagged_path = source.relative_to(dotfiles_dir)

    if not target.exists():
        error(f"{tilde_target} -> {tagged_path}", prefix="missing")
    elif target.is_symlink() and target.resolve() == source.resolve():
        info(f"{tilde_target} -> {tagged_path}", prefix="linked")
    elif target.is_file() and filecmp.cmp(source, target, shallow=False):
        error(f"{tilde_target} -> {tagged_path}", prefix="unlinked copy")
    else:
        error(f"{tilde_target} -> {tagged_path}", prefix="divergent")


def status(dotfiles_dir: Path) -> None:
    """List all managed files and their status relative to home."""
    for tag_dir in tag_dirs(dotfiles_dir):
        for path in files_in_tag(tag_dir):
            file_status(dotfiles_dir, tag_dir, path)


def parse_arguments() -> argparse.Namespace:
    """Parse command-line arguments."""
    parser = argparse.ArgumentParser(
        description="Dotfiles manager",
        formatter_class=argparse.ArgumentDefaultsHelpFormatter,
    )
    parser.add_argument(
        "-d",
        "--dotfiles-dir",
        metavar="DIR",
        type=lambda path: Path(path).resolve(),
        default=find_dotfiles_dir(),
        help="dotfiles directory",
    )

    subparsers = parser.add_subparsers(
        dest="command", required=True, help="subcommand to invoke"
    )

    import_parser = subparsers.add_parser(
        "import", help="import dotfiles into the source directory"
    )
    import_parser.add_argument(
        "-t",
        "--tag",
        required=True,
        type=normalise_tag,
        help="tag to import dotfiles into",
    )
    import_parser.add_argument(
        "paths", metavar="PATH", type=Path, nargs="+", help="path(s) to import"
    )
    import_parser.add_argument(
        "-n",
        "--dry-run",
        action="store_true",
        help="show what would be done without making changes",
    )

    link_parser = subparsers.add_parser(
        "link", help="symlink dotfiles to home directory"
    )
    link_parser.add_argument(
        "-n",
        "--dry-run",
        action="store_true",
        help="show what would be done without making changes",
    )

    subparsers.add_parser("status", help="list all dotfiles and their status")

    return parser.parse_args()


def main() -> None:
    """Command-line entry point."""
    args = parse_arguments()

    if not args.dotfiles_dir.exists():
        error(f"dotfiles directory {args.dotfiles_dir} does not exist")
        sys.exit(1)

    if args.command == "import":
        import_files(args.dotfiles_dir, args.paths, args.tag, dry_run=args.dry_run)
    elif args.command == "link":
        link_files(args.dotfiles_dir, dry_run=args.dry_run)
    else:
        status(args.dotfiles_dir)


if __name__ == "__main__":
    main()
