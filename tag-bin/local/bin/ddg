#!/usr/bin/env python3

import argparse
import webbrowser
from urllib.parse import urlencode


def main() -> None:
    """Open DuckDuckGo search for a query in the browser."""
    parser = argparse.ArgumentParser(description="Search DuckDuckGo")
    parser.add_argument("query", nargs="+", help="search query")
    args = parser.parse_args()

    params = {"q": " ".join(args.query)}
    url = f"https://html.duckduckgo.com/html/?{urlencode(params)}"
    webbrowser.open(url)


if __name__ == "__main__":
    main()
